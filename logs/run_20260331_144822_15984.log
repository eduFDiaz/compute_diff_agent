policy-map CUSTOMER_INTERNET_IN
  class CUSTOMER_PROTECTED
    police cir 64
    set qos-group 1
    set ip dscp default
  exit
  class ANY
    set qos-group 1
    set ip dscp default
  exit
exit

policy-map LAN_OUT
  class LAN_QOS_GROUP_AF1
  exit
exit

policy-map WAN_OUT
  class WAN_MANAGEMENT
    priority 1000
    set cos 4
  exit
  class WAN_ROUTING
    priority 1000
    set cos 7
  exit
  class QOS_GROUP_AF1
    bandwidth percent 100
    set cos 0
  exit
  class class-default
    set cos 0
  exit
exit

policy-map PARENT_WAN_OUT
  class ANY
    shape-average 1000000
    service-policy WAN_OUT
  exit
exit

policy-map WAN_IN_DR
  class BGP_TRAFFIC
  exit
  class CUSTOMER_PROTECTED
    police cir 64
    set qos-group 21
  exit
  class ANY
    police cir 1000000
    set qos-group 21
  exit
exit

policy-map WAN_IN_MEA
  class DR_VLANS
    service-policy WAN_IN_DR
  exit
exit

